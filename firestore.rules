rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: prompts
    // Document ID: {promptId}
    // Fields:
    //   - id: string (required) - Unique ID for the prompt
    //   - name: string (required) - Name of the prompt (max 100 chars)
    //   - prompt: string (required) - The prompt text (max 5000 chars)
    //   - type: string (required) - "generate" or "tryon"
    //   - uid: string (required) - Owner's UID
    //   - createdAt: timestamp (required) - Creation time
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "trungg9870@gmail.com" && request.auth.token.email_verified == true));
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidPrompt(data) {
      return data.id is string &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.prompt is string && data.prompt.size() > 0 && data.prompt.size() <= 5000 &&
             data.type in ['generate', 'tryon', 'ecom'] &&
             data.uid is string &&
             data.createdAt is timestamp &&
             (!('isDefault' in data) || data.isDefault is bool);
    }

    function isValidModel(data) {
      return data.id is string &&
             data.imageUrl is string && data.imageUrl.size() > 0 && data.imageUrl.size() <= 1500000 &&
             data.uid == request.auth.uid &&
             data.createdAt is timestamp;
    }

    function isValidUser(data) {
      return data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'user'] &&
             data.canUseClothing is bool &&
             data.canUseEcom is bool &&
             data.createdAt is timestamp;
    }

    match /prompts/{promptId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.uid == request.auth.uid || isAdmin() || ('isDefault' in resource.data && resource.data.isDefault == true));
      allow create: if isAuthenticated() && hasRequiredFields(['id', 'name', 'prompt', 'type', 'uid', 'createdAt']) && isValidPrompt(request.resource.data) && (isAdmin() || (!('isDefault' in request.resource.data) || request.resource.data.isDefault == false) && request.resource.data.uid == request.auth.uid);
      allow update: if isAuthenticated() && isValidPrompt(request.resource.data) && (isAdmin() || (resource.data.uid == request.auth.uid && (!('isDefault' in resource.data) || resource.data.isDefault == false)));
      allow delete: if isAuthenticated() && (isAdmin() || (resource.data.uid == request.auth.uid && (!('isDefault' in resource.data) || resource.data.isDefault == false)));
    }

    match /models/{modelId} {
      // Read: owner, admin, hoặc bất kỳ user đăng nhập nếu doc được đánh dấu isShared.
      // Doc shared = "Mẫu chung Otama" — tất cả nick trong shop dùng chung.
      allow read: if isAuthenticated() && (
        resource == null ||
        resource.data.uid == request.auth.uid ||
        isAdmin() ||
        ('isShared' in resource.data && resource.data.isShared == true)
      );
      allow create: if isAuthenticated() && hasRequiredFields(['id', 'imageUrl', 'uid', 'createdAt']) && isValidModel(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin()) && isValidModel(request.resource.data) && request.resource.data.uid == resource.data.uid;
      allow delete: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
    }

    match /rooms/{roomId} {
      // Read: owner, admin, hoặc bất kỳ user đăng nhập nếu doc được đánh dấu isShared.
      // Doc shared = "Giường chung Otama" — tất cả nick trong shop dùng chung.
      allow read: if isAuthenticated() && (
        resource == null ||
        resource.data.uid == request.auth.uid ||
        isAdmin() ||
        ('isShared' in resource.data && resource.data.isShared == true)
      );
      allow create: if isAuthenticated() && hasRequiredFields(['id', 'imageUrl', 'uid', 'createdAt']) && isValidModel(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin()) && isValidModel(request.resource.data) && request.resource.data.uid == resource.data.uid;
      allow delete: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
    }

    // Usage logs (Admin analytics): bất kỳ user đăng nhập đều ghi được log của mình;
    // chỉ admin đọc. Không cho sửa/xóa để giữ tính toàn vẹn số liệu.
    match /usage/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // Lịch sử ảnh gen của từng user (giữ 15 ngày, sweep phía client).
    // - Ghi: chỉ ghi doc có uid == auth.uid (không giả mạo owner).
    // - Đọc: chủ doc hoặc admin. Query `where uid == auth.uid` sẽ pass vì mỗi doc trả về đều thoả điều kiện.
    // - Xoá: chủ doc hoặc admin (dùng cho sweep 15 ngày + nút xoá thủ công).
    // - Update: chặn hoàn toàn để giữ nguyên trạng.
    match /history/{historyId} {
      allow read: if isAuthenticated() && (isDocOwner() || isAdmin());
      allow create: if isAuthenticated()
                     && request.resource.data.uid == request.auth.uid
                     && request.resource.data.keys().hasAll(['uid', 'url', 'ts', 'feature']);
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
      allow update: if false;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data) && (!('role' in request.resource.data) || request.resource.data.role == resource.data.role || isAdmin()) && (!('canUseClothing' in request.resource.data) || request.resource.data.canUseClothing == resource.data.canUseClothing || isAdmin()) && (!('canUseEcom' in request.resource.data) || request.resource.data.canUseEcom == resource.data.canUseEcom || isAdmin());
    }
  }
}
